# --- Model selection -------------------------------------------------------
# The agent auto-detects a provider from the API keys present below. To pin a
# specific provider/model, set these explicitly.
#
# Recommended for this project: route through OpenRouter to Anthropic models.
# MODEL_PROVIDER=openrouter
# MODEL_ID=anthropic/claude-opus-4.8     # or anthropic/claude-sonnet-4.6
#
# Direct Anthropic instead:
# MODEL_PROVIDER=anthropic
# MODEL_ID=claude-sonnet-4-5
#
# OpenRouter model ids are namespaced (vendor/model), e.g. openai/gpt-4o,
# google/gemini-2.5-pro.
#
# Reasoning/thinking effort: off | minimal | low | medium | high | xhigh
# THINKING_LEVEL=medium

# --- Provider API keys -----------------------------------------------------
# Provide at least one. When several are present, the first of
# anthropic > openrouter > openai with a key wins (unless MODEL_PROVIDER is set).
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Web search (Exa) ------------------------------------------------------
# Used by the web_search and external_events investigators. Without it, a stub
# returns placeholder results (the chain still runs). Get a key at exa.ai.
# EXA_API_KEY=

# --- Context-fetcher (real cluster context) --------------------------------
# Base URL of the `context-fetcher` service (the context-fetcher/ submodule). It
# returns one structured brief per service — live k8s manifest, pod/workload
# state + events, curated Prometheus metrics, Loki access logs, and pod logs.
# When set, this provider runs AND the grafana/kubernetes/load-balancer stubs
# stand down (it supplies the same signals from the real cluster).
#   in-cluster:    http://context-fetcher.ai-agent:8080
#   port-forward:  http://localhost:8080
# CONTEXT_FETCHER_URL=http://localhost:8080
#
# Which service to fetch. If unset, the provider pulls a "<ns/name>" id (e.g.
# demo/whoami) out of the trigger, falling back to a known catalog name.
# CONTEXT_FETCHER_SERVICE=demo/whoami
# Namespace to pair with a derived bare service name.
# CONTEXT_FETCHER_NAMESPACE=demo
# Look-back window in seconds (default 180 = 3 min) and request timeout in ms.
# CONTEXT_FETCHER_WINDOW_SECONDS=180
# CONTEXT_FETCHER_TIMEOUT_MS=30000

# --- External-events provider (opt-in) -------------------------------------
# The external-events investigation is agent-pulled by default. Set this to also
# run it as a deterministic context-gathering source every incident.
# EXTERNAL_EVENTS_PROVIDER=1

# --- Suggested-fix PR (optional) -------------------------------------------
# Repo the suggest-fix-pr dispatcher targets when it can't resolve one. owner/repo.
# FIX_PR_REPO=acme/storefront

# --- HTTP server (npm run serve) -------------------------------------------
# Port the agent HTTP service listens on (container default 8000).
# PORT=8000
# Shared secret. When set, POST /incidents requires it as the X-API-Key header
# (mirrors the slack-alerting convention). Empty = auth disabled.
# AGENT_API_KEY=

# --- Convenience -----------------------------------------------------------
# Experiment with both models without editing MODEL_ID:
#   npm run dev:opus     -> anthropic/claude-opus-4.8 via OpenRouter
#   npm run dev:sonnet   -> anthropic/claude-sonnet-4.6 via OpenRouter
#   npm run doctor       -> preflight: model, podman, sandbox, GitHub App
#   npm run file-issue   -> end-to-end test of the github subagent (issue + PR)

# --- GitHub App (used by the github subagent) ------------------------------
# The github subagent clones the target repo into a podman sandbox and runs
# `gh`/`git` there, authenticated with a short-lived, repo-scoped token minted
# from a GitHub App. It always files an issue and, when a concrete low-risk fix
# is implied, opens a DRAFT suggested-fix PR (open-only — it never merges).
# Without these, the subagent reports "not configured" instead of filing
# anything (it never fabricates a result).
#
# The App needs these repository permissions on the target repo:
#   - Issues: Read & write
#   - Contents: Read & write        (to clone and push a fix branch)
#   - Pull requests: Read & write   (to open the draft PR)
#
# The App's ID or client ID (the JWT issuer):
# GITHUB_APP_ID=
#
# The App's RSA private key. Provide EITHER the PEM contents inline (literal
# "\n" newlines are accepted)...
# GITHUB_APP_PRIVATE_KEY=
# ...OR a path to the .pem file:
# GITHUB_APP_PRIVATE_KEY_PATH=./secrets/app.private-key.pem
#
# Optional: pin the installation id (otherwise it is resolved per repo).
# GITHUB_APP_INSTALLATION_ID=
#
# Optional: GitHub Enterprise Server API base URL.
# GITHUB_API_BASE_URL=https://api.github.com

# --- Sandbox ---------------------------------------------------------------
# Container image used for the `gh` sandbox. Defaults to a public image that
# bundles gh + git (auto-pulled by podman on first use). Pin a version tag for
# reproducibility if you like, e.g. docker.io/maniator/gh:v2.92.0.
# GITHUB_SANDBOX_IMAGE=docker.io/maniator/gh:latest
