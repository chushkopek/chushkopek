{
  "name": "chushkopek-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Autonomous L1 DevOps on-call agent. Triages incidents, attempts safe runbook-level remediation, and escalates.",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "chushkopek": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "dev:opus": "MODEL_PROVIDER=openrouter MODEL_ID=anthropic/claude-opus-4.8 tsx src/cli.ts",
    "dev:sonnet": "MODEL_PROVIDER=openrouter MODEL_ID=anthropic/claude-sonnet-4.6 tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "doctor": "tsx src/scripts/doctor.ts",
    "file-issue": "tsx src/scripts/file-issue.ts"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.78.1",
    "@earendil-works/pi-ai": "^0.78.1",
    "dotenv": "^17.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
